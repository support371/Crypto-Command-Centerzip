# ============================================================
# ENVIRONMENT VARIABLES — COPY TO .env AND FILL IN VALUES
# NEVER commit .env to version control
# ============================================================

# --- App ---
NODE_ENV=development
APP_ENV=development          # development | testnet | production

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Execution Core ---
EXECUTION_CORE_URL=http://localhost:8000
EXECUTION_CORE_API_KEY=your-internal-api-key

# --- PostgreSQL + TimescaleDB ---
DATABASE_URL=postgresql://user:password@localhost:5432/tradingdb
TIMESCALE_URL=postgresql://user:password@localhost:5432/tradingdb

# --- Redis ---
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# --- Exchange Credentials (TESTNET ONLY until validated) ---
BTCC_API_KEY=
BTCC_API_SECRET=
BTCC_TESTNET=true

BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_PASSPHRASE=
BITGET_TESTNET=true

# --- CCXT Pro ---
CCXT_SANDBOX_MODE=true

# --- Prediction Bot ---
PREDICTION_BOT_URL=http://localhost:8001
PREDICTION_BOT_API_KEY=your-prediction-bot-key

# --- Guardian Bot ---
GUARDIAN_BOT_URL=http://localhost:8002
GUARDIAN_BOT_API_KEY=your-guardian-bot-key

# --- Kill-Switch ---
KILL_SWITCH_SECRET=your-kill-switch-secret
AUTO_KILL_DRAWDOWN_PCT=5.0
AUTO_KILL_LOSS_USD=1000.0

# --- Risk Limits ---
MAX_POSITION_SIZE_USD=10000
MAX_DAILY_LOSS_USD=500
MAX_OPEN_POSITIONS=10

# --- Logging ---
LOG_LEVEL=INFO
AUDIT_LOG_ENABLED=true
